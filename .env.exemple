# Bricks AI V30 - real knowledge packs + local grids/pages/cases + convergence
# Local-only build. No remote GPU delegation.

# Local compute preference: auto | gpu | cpu
BRICKS_AI_DEVICE=auto

# Provider routing: ollama-only | local-first | cloud-only | round-robin
BRICKS_AI_PROVIDER_MODE=local-first
BRICKS_AI_DEBUG_PROVIDERS=true

# Ollama local provider
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:latest
OLLAMA_TIMEOUT_SECONDS=900
OLLAMA_JSON_FORMAT=false
OLLAMA_NUM_PREDICT=1024
OLLAMA_MIN_SECONDS_BETWEEN_REQUESTS=1
OLLAMA_REQUESTS_PER_MINUTE=60
OLLAMA_RATE_LIMIT_COOLDOWN_SECONDS=10
OLLAMA_FAILURE_COOLDOWN_SECONDS=5

# Optional API providers. Leave empty until needed.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MIN_SECONDS_BETWEEN_REQUESTS=6
OPENAI_REQUESTS_PER_MINUTE=10
OPENAI_RATE_LIMIT_COOLDOWN_SECONDS=60
OPENAI_FAILURE_COOLDOWN_SECONDS=20

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_MIN_SECONDS_BETWEEN_REQUESTS=10
ANTHROPIC_REQUESTS_PER_MINUTE=6
ANTHROPIC_RATE_LIMIT_COOLDOWN_SECONDS=90
ANTHROPIC_FAILURE_COOLDOWN_SECONDS=20

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MIN_SECONDS_BETWEEN_REQUESTS=6
GEMINI_REQUESTS_PER_MINUTE=10
GEMINI_RATE_LIMIT_COOLDOWN_SECONDS=60
GEMINI_FAILURE_COOLDOWN_SECONDS=20

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_MIN_SECONDS_BETWEEN_REQUESTS=8
MISTRAL_REQUESTS_PER_MINUTE=7
MISTRAL_RATE_LIMIT_COOLDOWN_SECONDS=60
MISTRAL_FAILURE_COOLDOWN_SECONDS=20

XAI_API_KEY=
XAI_MODEL=grok-2-latest
XAI_MIN_SECONDS_BETWEEN_REQUESTS=10
XAI_REQUESTS_PER_MINUTE=6
XAI_RATE_LIMIT_COOLDOWN_SECONDS=90
XAI_FAILURE_COOLDOWN_SECONDS=20

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MIN_SECONDS_BETWEEN_REQUESTS=8
DEEPSEEK_REQUESTS_PER_MINUTE=7
DEEPSEEK_RATE_LIMIT_COOLDOWN_SECONDS=60
DEEPSEEK_FAILURE_COOLDOWN_SECONDS=20

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_MIN_SECONDS_BETWEEN_REQUESTS=6
GROQ_REQUESTS_PER_MINUTE=10
GROQ_RATE_LIMIT_COOLDOWN_SECONDS=60
GROQ_FAILURE_COOLDOWN_SECONDS=20

TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
TOGETHER_MIN_SECONDS_BETWEEN_REQUESTS=6
TOGETHER_REQUESTS_PER_MINUTE=10
TOGETHER_RATE_LIMIT_COOLDOWN_SECONDS=60
TOGETHER_FAILURE_COOLDOWN_SECONDS=20

# Trainer scale
BRICKS_AI_STEPS=500
BRICKS_AI_ITEMS_PER_THEME=8
BRICKS_AI_SUBTHEMES_PER_THEME=4
BRICKS_AI_MAX_DEPTH=2
BRICKS_AI_CHECKPOINT=bricks_ai_checkpoint.bin
BRICKS_AI_AUTO_EXTEND_ON_EMPTY_RESUME=true
BRICKS_AI_GRID_COUNT=16
BRICKS_AI_CASES_PER_GRID=4096
BRICKS_AI_MEMORY_MODE=balanced

# Internal expansion/validation budget per requested trained item.
BRICKS_AI_MAX_INTERNAL_TICKS_PER_STEP=24

# Benchmark report outputs written at the end of training.
BRICKS_AI_BENCHMARK_JSON=benchmark_report.json
BRICKS_AI_BENCHMARK_CSV=benchmark_report.csv

# Parallel Dimensions Engine: several deterministic realities race on the same item.
BRICKS_AI_PARALLEL_DIMENSIONS_ENABLED=true
BRICKS_AI_PARALLEL_DIMENSIONS=16
BRICKS_AI_DIMENSION_SELECTION=best_validated
BRICKS_AI_DIMENSION_CROSS_VALIDATE=true
BRICKS_AI_DIMENSION_MIN_AGREEMENT=2
BRICKS_AI_DIMENSION_MAX_CROSS_VALIDATIONS=7
BRICKS_AI_DIMENSION_LOSS_AGREEMENT_MARGIN=0.12
BRICKS_AI_DIMENSION_DIVERSITY_BONUS=0.10

# Knowledge Packs: local reusable teacher-built knowledge cache.
# hybrid = train from pack first, enrich with Ollama/API when missing.
# pack-only = train only from local packs, no provider generation.
# continuous-only = old behavior, ask provider continuously without using packs.
BRICKS_AI_KNOWLEDGE_PACKS_ENABLED=true
BRICKS_AI_KNOWLEDGE_PACK_MODE=hybrid
BRICKS_AI_KNOWLEDGE_PACK_DIR=knowledge_packs
BRICKS_AI_KNOWLEDGE_PACK_TRAIN_FIRST=true
BRICKS_AI_KNOWLEDGE_PACK_SAVE_GENERATED=true
BRICKS_AI_KNOWLEDGE_PACK_MAX_REUSE_PER_ITEM=12

# V27 sleep/interruption detection and final convergence cube.
BRICKS_AI_SLEEP_GAP_THRESHOLD_MS=300000
BRICKS_AI_CONVERGENCE_ENABLED=true
BRICKS_AI_CONVERGENCE_CLUSTER_RADIUS=4
BRICKS_AI_CONVERGENCE_MIN_VOTES=2
BRICKS_AI_CONVERGENCE_REQUIRE_CROSS_VALIDATION=false
BRICKS_AI_CONVERGENCE_REINFORCE_SUPPORTING_PATHS=true
BRICKS_AI_CONVERGENCE_WEIGHT_VOTES=0.45
BRICKS_AI_CONVERGENCE_WEIGHT_CANDIDATE_SCORE=0.20
BRICKS_AI_CONVERGENCE_WEIGHT_LOSS_REWARD=0.20
BRICKS_AI_CONVERGENCE_WEIGHT_STABILITY=0.15
BRICKS_AI_DIMENSION_CONVERGE_OUTPUTS=true
BRICKS_AI_DIMENSION_OUTPUT_CONVERGENCE_RADIUS=4
BRICKS_AI_CONVERGENCE_FINAL_BOOST_REPEATS=2
BRICKS_AI_CONVERGENCE_PATH_BOOST_REPEATS=1

# V30.4 correlation survival reinforcement: validated paths progressively strengthen surviving links.
BRICKS_AI_CONVERGENCE_CORRELATION_BOOST_REPEATS=2
BRICKS_AI_CONVERGENCE_CORRELATION_SCORE_BOOST=2.2
BRICKS_AI_CONVERGENCE_CORRELATION_COEFFICIENT_BOOST=1.6
BRICKS_AI_CONVERGENCE_CORRELATION_SURVIVAL_MIN_VISITS=3
BRICKS_AI_CONVERGENCE_CORRELATION_SURVIVAL_BONUS=0.012

# V29 pre-final destruction gate: invalid candidate realities are destroyed before the final cube.
BRICKS_AI_PREFINAL_DESTRUCTION_ENABLED=true
BRICKS_AI_PREFINAL_MIN_CANDIDATE_SCORE=0.78
BRICKS_AI_PREFINAL_MAX_CANDIDATE_LOSS=0.35
BRICKS_AI_PREFINAL_MIN_ALIGNMENT_SCORE=0.78
BRICKS_AI_PREFINAL_PROTECT_CASE_CONFIDENCE=0.18
BRICKS_AI_PREFINAL_DESTROY_MIDDLE_NODES=true
BRICKS_AI_PREFINAL_DESTROY_OUTPUT_NODES=true
BRICKS_AI_PREFINAL_ALWAYS_KEEP_BEST_CANDIDATE=true

# V30 real knowledge packs: no more 1KB one-question cache treated as knowledge.
BRICKS_AI_KNOWLEDGE_PACK_MIN_ITEMS_PER_DOMAIN=96
BRICKS_AI_KNOWLEDGE_PACK_MIN_TOPICS=8
BRICKS_AI_KNOWLEDGE_PACK_MIN_SUBTOPICS=24
BRICKS_AI_KNOWLEDGE_PACK_MIN_CONCEPTS=48
BRICKS_AI_KNOWLEDGE_PACK_BUILD_DEPTH=3
BRICKS_AI_KNOWLEDGE_PACK_REQUIRE_COVERAGE=true
BRICKS_AI_KNOWLEDGE_PACK_REJECT_TINY_PACKS=true
BRICKS_AI_KNOWLEDGE_PACK_EXTRACTION_ITEMS_PER_CONCEPT=3
# Large structured JSON packs need more output tokens than simple QA.
OLLAMA_NUM_PREDICT=1024
OLLAMA_TIMEOUT_SECONDS=900

# V30.2 - chunked real knowledge-pack builder for local Ollama/CPU
BRICKS_AI_KNOWLEDGE_PACK_BUILD_CHUNKED=true
BRICKS_AI_KNOWLEDGE_PACK_CHUNK_SUBTOPICS_PER_TOPIC=3
BRICKS_AI_KNOWLEDGE_PACK_CHUNK_CONCEPTS_PER_SUBTOPIC=2
BRICKS_AI_KNOWLEDGE_PACK_MAX_BUILD_CHUNKS=8
BRICKS_AI_KNOWLEDGE_PACK_ALLOW_LIVE_FALLBACK=false

# V30.3: CPU-safe real pack building. Use local structured bootstrap first, then optional provider enrichment.
BRICKS_AI_KNOWLEDGE_PACK_LOCAL_BOOTSTRAP_FIRST=true
BRICKS_AI_KNOWLEDGE_PACK_PROVIDER_ENRICHMENT=false
OLLAMA_TIMEOUT_SECONDS=900
OLLAMA_NUM_PREDICT=1024
